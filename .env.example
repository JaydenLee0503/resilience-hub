# Frontend (Vite) environment — copy to .env.local and fill in.
# Only VITE_-prefixed, NON-SECRET values may live here; they ship to the browser.

# URL of the deployed/served analyze Edge Function.
# Local Supabase dev default:
VITE_ANALYZE_FUNCTION_URL=http://localhost:54321/functions/v1/analyze
# Deployed example:
# VITE_ANALYZE_FUNCTION_URL=https://<project-ref>.functions.supabase.co/analyze

# Supabase anon (public) key — required only when the function verifies JWTs.
# This is NOT a secret in the dangerous sense (it is the public anon key), but
# leave it blank for local `--no-verify-jwt` development.
# VITE_SUPABASE_ANON_KEY=

# .env.example — copy to .env and fill in values. Never commit .env.
# See CLAUDE.md §9 for security rules.

# ── Server-side only (never VITE_ prefixed) ───────────────────────────────────
# Your Featherless API settings. Used by server/dev.js in development.
# Keep these server-side only. Do not prefix with VITE_.
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── Client-safe (VITE_ prefix, non-secret) ───────────────────────────────────
# Required in production to point the client at your Supabase Edge Function.
# Leave empty during local development (the client calls localhost:3001 instead).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: override the /api/analyze URL entirely (staging, custom backend, etc.)
# VITE_ANALYZE_URL=https://your-staging.supabase.co/functions/v1/analyze
