# .env.example — copy to .env and fill in values. Never commit .env.
# See CLAUDE.md §9 and the README for the full rules.
#
#   cp .env.example .env
#
# Only VITE_-prefixed, NON-SECRET values ship to the browser. Secrets (the
# Featherless key) must NEVER be VITE_-prefixed — they stay server-side.

# ── Server-side only (used by server/dev.js; never VITE_ prefixed) ────────────
# Without FEATHERLESS_API_KEY the dev server runs in demo mode (canned output).
FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct
# Optional: change the local dev API server port (default 3001).
# DEV_SERVER_PORT=3001

# ── Client-safe (VITE_ prefix, non-secret) ───────────────────────────────────
# Required for auth + saved reports, and for the prod analyze/chat endpoints
# (the client calls ${VITE_SUPABASE_URL}/functions/v1/analyze in production).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Optional overrides — point the client at a custom/staging backend.
# In development the client always calls http://localhost:3001 regardless.
# VITE_ANALYZE_URL=https://your-staging.supabase.co/functions/v1/analyze
# VITE_CHAT_URL=https://your-staging.supabase.co/functions/v1/analyze
