# Server-side secrets for Edge Functions. Copy to `.env` (gitignored) for local dev.
# NEVER commit the real key. In production set it with:
#   supabase secrets set FEATHERLESS_API_KEY=...
#   supabase secrets set FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

FEATHERLESS_API_KEY=
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=Qwen/Qwen2.5-72B-Instruct

# Optional: lock CORS to your deployed frontend origin in production.
# ALLOWED_ORIGIN=https://your-app.vercel.app
